\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{pratiqueja}[2026/05/28 PratiqueJa Apostila Template]

% ── Idioma e fonte ────────────────────────────────────────────
\RequirePackage[brazil]{babel}
\RequirePackage{fontspec}
\setmainfont{Inter 18pt}
\RequirePackage{microtype}

% ── Página ────────────────────────────────────────────────────
\RequirePackage[a4paper, top=1.5cm, bottom=2.8cm,
                left=1.5cm, right=1.5cm]{geometry}
\setlength{\footskip}{1.3cm}

% ── Paleta de cores ───────────────────────────────────────────
\RequirePackage[dvipsnames,svgnames,table]{xcolor}

\definecolor{darkblue}{HTML}{1E3A8A}
\definecolor{accentblue}{HTML}{38BDF8}
\definecolor{graycolor}{HTML}{64748B}
\definecolor{vegreen}{HTML}{22C55E}
\definecolor{vered}{HTML}{EF4444}
\definecolor{badgepurple}{HTML}{7C3AED}
\definecolor{badgegreen}{HTML}{059669}

\definecolor{rulebg}{HTML}{EEF2FF}
\definecolor{exbg}{HTML}{F8FAFC}
\definecolor{obsbg}{HTML}{F9FAFB}
\definecolor{exborder}{HTML}{E2E8F0}
\definecolor{sepcolor}{HTML}{E2E8F0}
\definecolor{bodytext}{HTML}{374151}
\definecolor{titletext}{HTML}{0F172A}
\definecolor{mutedtext}{HTML}{64748B}

\definecolor{notebg}{HTML}{FFFBEB}
\definecolor{noteborder}{HTML}{F59E0B}
\definecolor{notetext}{HTML}{78350F}

% ── Pacotes de conteúdo ───────────────────────────────────────
\RequirePackage{amsmath,amssymb}
\RequirePackage{multicol}
\RequirePackage{setspace}
\RequirePackage{parskip}
\RequirePackage{graphicx}
\RequirePackage{array}
\RequirePackage{needspace}
\RequirePackage[most]{tcolorbox}
\tcbuselibrary{skins, breakable}

% ── Rodapé configurável ───────────────────────────────────────
\newcommand{\pj@subject}{Assunto}
\newcommand{\setsubject}[1]{\renewcommand{\pj@subject}{#1}}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0.6pt}
\renewcommand{\footrule}{%
  {\color{sepcolor}%
   \vskip-3.5pt\vskip-\footrulewidth%
   \hrule\@width\headwidth\@height\footrulewidth%
   \vskip 3.5pt}}
\fancyfoot[L]{\small\color{mutedtext}%
  \textbf{Pratique}\textcolor{darkblue}{\textbf{Já}}}
\fancyfoot[C]{\small\color{mutedtext}\itshape \pj@subject}
\fancyfoot[R]{\small\color{mutedtext}\thepage}

% ============================================================
%  ATALHOS TIPOGRÁFICOS
% ============================================================
\newcommand{\hl}[1]{\textcolor{darkblue}{\textbf{#1}}}
\newcommand{\ok}{{\bfseries\textcolor{vegreen}{✓}}}
\newcommand{\nok}{{\bfseries\textcolor{vered}{✗}}}

% ============================================================
%  COMPONENTES VISUAIS
% ============================================================

% ── Cabeçalho da apostila ─────────────────────────────────────
% #1 = título  #2 = subtítulo  #3 = categoria (ex: Matemática · Intermediário)
\newcommand{\heroheader}[3]{%
  \begin{tcolorbox}[
    enhanced, arc=0pt, boxrule=0pt,
    colback=white, colframe=white,
    left=14pt, right=14pt, top=10pt, bottom=10pt,
    borderline west={5pt}{0pt}{darkblue},
    borderline south={0.8pt}{0pt}{sepcolor},
  ]
    \noindent
    {\color{titletext}\fontsize{20}{24}\selectfont\bfseries #1}\hfill
    {\color{mutedtext}\small
      \textbf{Pratique}\textcolor{darkblue}{\textbf{Já}}
      \ ·\ \itshape #3}\par
    \vspace{2pt}
    {\color{mutedtext}\normalsize\itshape #2}
  \end{tcolorbox}%
  \vspace{6pt}%
}

% ── Badge inline ──────────────────────────────────────────────
% #1 = texto  #2 = cor de fundo
\newcommand{\badge}[2]{%
  \tcbox[
    on line, enhanced, arc=5pt, boxrule=0pt,
    colback=#2, colframe=#2,
    left=5pt, right=5pt, top=3pt, bottom=3pt,
    nobeforeafter,
  ]{\small\bfseries\color{white}#1}%
}

% ── Cabeçalho de seção ────────────────────────────────────────
% #1 = rótulo do badge  #2 = cor  #3 = título  #4 = subtítulo
\newcommand{\TW}[4]{%
  \needspace{5\baselineskip}%
  \noindent{\color{#2}\rule{\linewidth}{2pt}}\par\nopagebreak
  \vspace{3pt}%
  \noindent\badge{#1}{#2}\hspace{6pt}%
  {\color{titletext}\bfseries\normalsize #3}\\[1pt]
  {\color{mutedtext}\small\itshape #4}%
  \par\nopagebreak
  \vspace{-4pt}%
  {\color{sepcolor}\rule{\linewidth}{0.8pt}}%
}

% ── Caixa de regra ────────────────────────────────────────────
\newcommand{\regra}[1]{%
  \begin{tcolorbox}[
    breakable, enhanced jigsaw, arc=0pt, boxrule=0pt,
    colback=rulebg, colframe=rulebg,
    left=10pt, right=8pt, top=6pt, bottom=6pt,
    borderline west={3.5pt}{0pt}{darkblue},
  ]
    \color{darkblue}\small #1
  \end{tcolorbox}%
  \vspace{2pt}%
}

% ── Caixa de exemplos ─────────────────────────────────────────
\newcommand{\exemp}[1]{%
  \vspace{2pt}%
  \begin{tcolorbox}[
    breakable, enhanced jigsaw,
    arc=5pt, boxrule=0.6pt,
    colback=exbg, colframe=exborder,
    left=9pt, right=9pt, top=5pt, bottom=5pt,
  ]
    \setlength{\parskip}{1.5pt}%
    \setlength{\lineskiplimit}{4pt}%
    \setlength{\lineskip}{7pt}%
    \small\color{bodytext}#1
  \end{tcolorbox}%
  \vspace{1pt}%
}

% ── Caixa de fórmula ──────────────────────────────────────────
\newcommand{\formula}[1]{%
  \vspace{3pt}%
  \begin{tcolorbox}[
    arc=5pt, boxrule=0.8pt,
    colback=rulebg, colframe=darkblue,
    left=10pt, right=10pt, top=7pt, bottom=7pt,
  ]
    \centering\color{darkblue}\normalsize\bfseries #1
  \end{tcolorbox}%
  \vspace{3pt}%
}

% ── Caixa de observação ───────────────────────────────────────
\newcommand{\obs}[1]{%
  \vspace{2pt}%
  \begin{tcolorbox}[
    enhanced, arc=0pt, boxrule=0pt,
    colback=obsbg, colframe=obsbg,
    left=8pt, right=8pt, top=4pt, bottom=4pt,
    borderline west={2.5pt}{0pt}{graycolor},
  ]
    {\color{graycolor}\fontsize{7.5}{9}\selectfont\bfseries OBS\ }%
    \setlength{\lineskiplimit}{4pt}%
    \setlength{\lineskip}{7pt}%
    \small\color{bodytext}#1
  \end{tcolorbox}%
  \vspace{1pt}%
}

% ── Rótulo interno (sub-seção discreta) ───────────────────────
\newcommand{\SH}[1]{%
  \vspace{4pt}%
  \noindent{\color{mutedtext}\fontsize{7.5}{9}\selectfont
            \bfseries\MakeUppercase{#1}}\par
  \vspace{1pt}%
}

% ── Caixa de nota / dica (fundo amarelo) ─────────────────────
% Equivalente ao .tr-note da web — para atalhos e dicas importantes
\newcommand{\nota}[1]{%
  \vspace{2pt}%
  \begin{tcolorbox}[
    enhanced, arc=0pt, boxrule=0pt,
    colback=notebg, colframe=notebg,
    left=8pt, right=8pt, top=4pt, bottom=4pt,
    borderline west={2.5pt}{0pt}{noteborder},
  ]
    \setlength{\lineskiplimit}{4pt}%
    \setlength{\lineskip}{7pt}%
    \small\color{notetext}#1
  \end{tcolorbox}%
  \vspace{1pt}%
}

% ── Chip de item (ex: divisores) ──────────────────────────────
\newcommand{\chip}[1]{%
  \tcbox[
    on line, enhanced, arc=5pt, boxrule=0.5pt,
    colback=rulebg, colframe=exborder,
    left=4pt, right=4pt, top=2pt, bottom=2pt,
    nobeforeafter,
  ]{\small\bfseries\color{darkblue}#1}\hspace{2pt}%
}
